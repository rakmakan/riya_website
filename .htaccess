# Enable URL rewriting
RewriteEngine On

# Set default character set
AddDefaultCharset UTF-8

# Protect against some common attacks
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Protect sensitive files
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# Protect against directory listing
Options -Indexes

# SQLite database protection - modified to allow PHP access
<Files "portfolio.db">
  Order deny,allow
  Deny from all
  Allow from env=REDIRECT_STATUS
</Files>

# PHP error handling - Using a different approach that's compatible with SiteGround
<IfModule mod_php.c>
  php_value display_errors 1
  php_value display_startup_errors 1
</IfModule>
