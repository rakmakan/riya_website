---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/work-with-me', label: 'Work With Me' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  style="
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 950;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem var(--gutter);
    background: rgba(250, 247, 242, 0.0);
    transition: background 0.4s ease, box-shadow 0.4s ease;
  "
>
  <!-- Logo -->
  <a
    href="/"
    aria-label="Airy Alps — Home"
    style="
      display: inline-flex;
      align-items: center;
      cursor: none;
      text-decoration: none;
      flex-shrink: 0;
    "
  >
    <img
      src="/images/logo.png"
      alt="Airy Alps"
      style="
        height: 40px;
        width: auto;
        display: block;
      "
    />
  </a>

  <!-- Desktop nav -->
  <nav aria-label="Primary navigation" style="display:flex; align-items:center; gap:2.5rem;">
    <ul style="list-style:none; display:flex; align-items:center; gap:2rem;" class="nav-links">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            style={`
              font-family: 'Jost', sans-serif;
              font-size: 0.8125rem;
              font-weight: 500;
              letter-spacing: 0.05em;
              text-decoration: none;
              cursor: none;
              transition: color 0.2s ease;
              color: ${(currentPath === href || (href !== '/' && currentPath.startsWith(href)))
                ? 'var(--sienna)'
                : 'var(--espresso)'};
            `}
            onmouseenter={`this.style.color='var(--sienna)'`}
            onmouseleave={`this.style.color='${(currentPath === href || (href !== '/' && currentPath.startsWith(href))) ? 'var(--sienna)' : 'var(--espresso)'}'`}
          >{label}</a>
        </li>
      ))}
    </ul>

    <a
      href="/contact"
      class="btn btn-primary"
      style="font-size:0.75rem; padding:0.625rem 1.25rem; cursor:none; white-space:nowrap;"
    >Book a Call</a>
  </nav>

  <!-- Mobile menu button -->
  <button
    id="menu-btn"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    style="
      display: none;
      background: none;
      border: none;
      padding: 0.25rem;
      cursor: none;
      flex-direction: column;
      gap: 5px;
      align-items: flex-end;
    "
    class="mobile-only"
  >
    <span id="b1" style="display:block; width:24px; height:1.5px; background:var(--espresso); transition:all 0.3s ease; border-radius:2px;"></span>
    <span id="b2" style="display:block; width:16px; height:1.5px; background:var(--espresso); transition:all 0.3s ease; border-radius:2px;"></span>
  </button>
</header>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  aria-hidden="true"
  style="
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 940;
    background: var(--parchment);
    padding: 5.5rem var(--gutter) 3rem;
    transform: translateY(-100%);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 8px 40px rgba(28, 21, 18, 0.08);
  "
>
  <nav>
    <ul style="list-style:none; display:flex; flex-direction:column; gap:0;">
      {[{ href: '/', label: 'Home' }, ...navLinks].map(({ href, label }) => (
        <li style="border-bottom: 1px solid var(--border);">
          <a
            href={href}
            style="
              display: block;
              font-family: 'Cormorant Garamond', serif;
              font-size: clamp(1.75rem, 6vw, 2.5rem);
              font-weight: 500;
              letter-spacing: -0.01em;
              color: var(--espresso);
              text-decoration: none;
              padding: 0.875rem 0;
              cursor: none;
              transition: color 0.2s ease;
            "
            onmouseenter="this.style.color='var(--sienna)'"
            onmouseleave="this.style.color='var(--espresso)'"
          >{label}</a>
        </li>
      ))}
    </ul>
    <div style="margin-top:2rem;">
      <a
        href="mailto:riyauppal777@gmail.com"
        style="font-family:'Jost',sans-serif; font-size:0.8125rem; color:var(--taupe); text-decoration:none; letter-spacing:0.04em; cursor:none;"
      >riyauppal777@gmail.com</a>
    </div>
  </nav>
</div>

<!-- Spacer — matches actual header height (logo 40px + 2×1.125rem padding ≈ 76px) -->
<div style="height: 4.75rem;" aria-hidden="true"></div>

<style>
  @media (max-width: 768px) {
    .nav-links { display: none !important; }
    .nav-links + a { display: none !important; }
    .mobile-only { display: flex !important; }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const btn = document.getElementById('menu-btn')!;
  const b1 = document.getElementById('b1')!;
  const b2 = document.getElementById('b2')!;
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    mobileMenu.style.transform = 'translateY(0)';
    mobileMenu.removeAttribute('aria-hidden');
    btn.setAttribute('aria-expanded', 'true');
    btn.setAttribute('aria-label', 'Close menu');
    b1.style.transform = 'translateY(3.25px) rotate(45deg)';
    b2.style.transform = 'translateY(-3.25px) rotate(-45deg)';
    b2.style.width = '24px';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    isOpen = false;
    mobileMenu.style.transform = 'translateY(-100%)';
    mobileMenu.setAttribute('aria-hidden', 'true');
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-label', 'Open menu');
    b1.style.transform = '';
    b2.style.transform = '';
    b2.style.width = '16px';
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', () => isOpen ? closeMenu() : openMenu());

  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  // Scroll: add background when scrolled
  window.addEventListener('scroll', () => {
    if (!isOpen) {
      const scrolled = window.scrollY > 40;
      header.style.background = scrolled
        ? 'rgba(250, 247, 242, 0.95)'
        : 'rgba(250, 247, 242, 0.0)';
      header.style.boxShadow = scrolled
        ? '0 1px 0 rgba(28, 21, 18, 0.08)'
        : 'none';
      header.style.backdropFilter = scrolled ? 'blur(16px)' : 'none';
    }
  }, { passive: true });
</script>
