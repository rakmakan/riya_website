---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: object | object[];
}

const { title, description, canonicalUrl = Astro.url.href, ogImage = '/images/og-default.jpg', schema } = Astro.props;
const schemaArray = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en" class="lenis">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Airy Alps" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {schemaArray.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Custom cursor -->
    <div class="cursor" id="cursor" aria-hidden="true"></div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Mark JS as ready — enables scroll-reveal & hero animations
      document.documentElement.classList.add('js-ready');

      // ─── Lenis smooth scroll ───────────────────
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.15,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
      (window as any).__lenis = lenis;

      // ─── Custom cursor ─────────────────────────
      const cursor = document.getElementById('cursor')!;
      let mx = window.innerWidth / 2, my = window.innerHeight / 2;
      let cx = mx, cy = my;

      document.addEventListener('mousemove', (e) => {
        mx = e.clientX; my = e.clientY;
      });

      // Smooth cursor follow
      (function animateCursor() {
        cx += (mx - cx) * 0.18;
        cy += (my - cy) * 0.18;
        cursor.style.left = cx + 'px';
        cursor.style.top  = cy + 'px';
        requestAnimationFrame(animateCursor);
      })();

      // Hover states
      document.querySelectorAll('a, button, [role="button"]').forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('is-hovering'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('is-hovering'));
      });
      document.querySelectorAll('input, textarea').forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('is-text'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('is-text'));
      });

      // ─── Scroll reveal via IntersectionObserver ──
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('[data-reveal], [data-stagger]').forEach(el => {
        revealObserver.observe(el);
      });
    </script>
  </body>
</html>
