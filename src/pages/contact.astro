---
import BaseLayout from '../layouts/BaseLayout.astro';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Airy Alps',
  description: 'Brand positioning consultancy for solopreneurs and DTC founders',
  founder: { '@type': 'Person', name: 'Riya Uppal', jobTitle: 'Brand Positioning Consultant' },
  email: 'riyauppal777@gmail.com',
  url: 'https://airyalps.com',
  address: { '@type': 'PostalAddress', addressLocality: 'Toronto', addressRegion: 'ON', addressCountry: 'CA' },
  areaServed: { '@type': 'GeoCircle', description: 'Global' },
  sameAs: ['https://linkedin.com/in/riya-uppal01'],
};
---

<BaseLayout
  title="Work With Riya Uppal | Airy Alps — Brand Positioning Consultant"
  description="Book a free 20-minute call with Riya Uppal to talk about your brand positioning. Based in Toronto. Working with solopreneurs and DTC founders globally."
  schema={localBusinessSchema}
>

<!-- ══════════════════════════════════════════════
     HERO
════════════════════════════════════════════════ -->
<section class="section-pad" aria-label="Contact hero" style="padding-top:clamp(3rem,6vw,5rem); border-bottom:1px solid var(--border);">
  <div class="wrap">
    <div style="max-width:36rem;">
      <span class="t-label" style="display:block; margin-bottom:1rem;" data-reveal>Contact</span>
      <h1 class="t-h1" style="margin-bottom:1.5rem;" data-reveal>
        Let's figure out what's off — and fix it.
      </h1>
      <p class="t-body" data-reveal>
        If your brand feels scattered, your message isn't landing, or you just can't articulate what makes you different — that's where I come in.
      </p>
      <p class="t-body" style="margin-top:1rem;" data-reveal>
        Start with a free 20-minute call. I'll listen, ask a few pointed questions, and tell you honestly where your positioning is breaking down and what I think you should do first.
      </p>
      <p class="t-quote" style="font-size:1.125rem; margin-top:1.25rem; color:var(--taupe);" data-reveal>
        No pitch. No pressure. Just a clear-eyed conversation.
      </p>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     CONTACT OPTIONS + FORM
════════════════════════════════════════════════ -->
<section class="section-pad" aria-label="Contact options">
  <div class="wrap">
    <div style="display:grid; grid-template-columns:1fr 2fr; gap:clamp(3rem,8vw,7rem); align-items:start;" class="contact-grid">

      <!-- Left: quick contact + process -->
      <div style="display:flex; flex-direction:column; gap:3rem;">

        <div data-reveal>
          <span class="t-label" style="display:block; margin-bottom:1.25rem;">Quick contact</span>
          <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div>
              <p class="t-label" style="color:var(--taupe); margin-bottom:0.375rem;">Book a free 20-min call</p>
              <p style="font-family:'Jost',sans-serif; font-size:0.875rem; font-style:italic; color:var(--taupe);">
                Calendar link coming soon — use the form for now.
              </p>
            </div>
            <div>
              <p class="t-label" style="color:var(--taupe); margin-bottom:0.375rem;">Email directly</p>
              <a
                href="mailto:riyauppal777@gmail.com"
                style="font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); text-decoration:none; transition:color 0.2s ease; cursor:none;"
                onmouseenter="this.style.color='var(--sienna)'"
                onmouseleave="this.style.color='var(--espresso)'"
              >riyauppal777@gmail.com</a>
            </div>
            <div>
              <p class="t-label" style="color:var(--taupe); margin-bottom:0.375rem;">LinkedIn</p>
              <a
                href="https://linkedin.com/in/riya-uppal01"
                target="_blank"
                rel="noopener noreferrer"
                style="font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); text-decoration:none; transition:color 0.2s ease; cursor:none;"
                onmouseenter="this.style.color='var(--sienna)'"
                onmouseleave="this.style.color='var(--espresso)'"
              >linkedin.com/in/riya-uppal01 ↗</a>
            </div>
          </div>
        </div>

        <div data-reveal>
          <span class="t-label" style="display:block; margin-bottom:1.25rem;">What happens next</span>
          <ol style="list-style:none; padding:0; display:flex; flex-direction:column; gap:1.25rem;">
            {[
              "You fill out the form (or drop me an email)",
              "We have a free 20-min call — I'll ask a few pointed questions",
              "I recommend the right starting point for your brand",
              "If it's a fit, we confirm scope, timeline, and get started",
            ].map((step, i) => (
              <li style="display:flex; align-items:flex-start; gap:1rem;">
                <span style="font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:500; color:color-mix(in srgb, var(--espresso) 18%, transparent); line-height:1; flex-shrink:0; padding-top:0.1rem;">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <p style="font-family:'Jost',sans-serif; font-size:0.875rem; line-height:1.65; color:color-mix(in srgb, var(--espresso) 65%, transparent);">{step}</p>
              </li>
            ))}
          </ol>
          <p style="font-family:'Jost',sans-serif; font-size:0.75rem; font-style:italic; color:var(--taupe); margin-top:1.25rem; line-height:1.6;">
            I work with a small number of clients at a time. If there's a waitlist, I'll let you know upfront.
          </p>
        </div>

      </div>

      <!-- Right: form -->
      <div data-reveal>

        <div
          id="form-success"
          style="display:none; border:1.5px solid rgba(196,96,58,0.3); background:rgba(196,96,58,0.05); padding:2rem; margin-bottom:2rem;"
        >
          <h3 class="t-h3" style="font-size:1.25rem;">Message received.</h3>
          <p class="t-body" style="margin-top:0.5rem;">I'll be in touch within 1–2 business days.</p>
        </div>

        <form id="contact-form" action="/api/contact" method="POST" novalidate>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem;" class="form-two-col">
            <div>
              <label for="name" class="t-label" style="display:block; margin-bottom:0.5rem; color:var(--taupe);">
                Your name <span style="color:var(--sienna);">*</span>
              </label>
              <input
                type="text" id="name" name="name" required autocomplete="name"
                placeholder="Riya Uppal"
                style="width:100%; border:1.5px solid var(--border); background:var(--parchment); padding:0.75rem 1rem; font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); outline:none; transition:border-color 0.2s ease; box-sizing:border-box;"
                onfocus="this.style.borderColor='var(--espresso)'"
                onblur="this.style.borderColor='var(--border)'"
              />
            </div>
            <div>
              <label for="email" class="t-label" style="display:block; margin-bottom:0.5rem; color:var(--taupe);">
                Your email <span style="color:var(--sienna);">*</span>
              </label>
              <input
                type="email" id="email" name="email" required autocomplete="email"
                placeholder="hello@yourbrand.com"
                style="width:100%; border:1.5px solid var(--border); background:var(--parchment); padding:0.75rem 1rem; font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); outline:none; transition:border-color 0.2s ease; box-sizing:border-box;"
                onfocus="this.style.borderColor='var(--espresso)'"
                onblur="this.style.borderColor='var(--border)'"
              />
            </div>
          </div>

          <div style="margin-bottom:1.5rem;">
            <label for="website" class="t-label" style="display:block; margin-bottom:0.5rem; color:var(--taupe);">
              Your website or Instagram handle
            </label>
            <input
              type="text" id="website" name="website"
              placeholder="airyalps.com or @yourbrand"
              style="width:100%; border:1.5px solid var(--border); background:var(--parchment); padding:0.75rem 1rem; font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); outline:none; transition:border-color 0.2s ease; box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--espresso)'"
              onblur="this.style.borderColor='var(--border)'"
            />
          </div>

          <div style="margin-bottom:1.5rem;">
            <label for="business" class="t-label" style="display:block; margin-bottom:0.5rem; color:var(--taupe);">
              In one sentence, what does your business do? <span style="color:var(--sienna);">*</span>
            </label>
            <input
              type="text" id="business" name="business" required
              placeholder="I help [audience] achieve [outcome] through [method]."
              style="width:100%; border:1.5px solid var(--border); background:var(--parchment); padding:0.75rem 1rem; font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); outline:none; transition:border-color 0.2s ease; box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--espresso)'"
              onblur="this.style.borderColor='var(--border)'"
            />
          </div>

          <div style="margin-bottom:1.5rem;">
            <label for="challenge" class="t-label" style="display:block; margin-bottom:0.5rem; color:var(--taupe);">
              What's the #1 thing that feels off about your brand right now? <span style="color:var(--sienna);">*</span>
            </label>
            <textarea
              id="challenge" name="challenge" required rows="4"
              placeholder="Be as specific as you can — the more honest, the more useful our first conversation will be."
              style="width:100%; border:1.5px solid var(--border); background:var(--parchment); padding:0.75rem 1rem; font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); outline:none; transition:border-color 0.2s ease; resize:none; box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--espresso)'"
              onblur="this.style.borderColor='var(--border)'"
            ></textarea>
          </div>

          <div style="margin-bottom:1.5rem;">
            <label for="referral" class="t-label" style="display:block; margin-bottom:0.5rem; color:var(--taupe);">
              How did you find Airy Alps?
            </label>
            <select
              id="referral" name="referral"
              style="width:100%; border:1.5px solid var(--border); background:var(--parchment); padding:0.75rem 1rem; font-family:'Jost',sans-serif; font-size:0.875rem; color:var(--espresso); outline:none; transition:border-color 0.2s ease; appearance:none; cursor:pointer; box-sizing:border-box;"
              onfocus="this.style.borderColor='var(--espresso)'"
              onblur="this.style.borderColor='var(--border)'"
            >
              <option value="">Select one</option>
              <option value="linkedin">LinkedIn</option>
              <option value="google">Google search</option>
              <option value="referral">Referred by someone</option>
              <option value="instagram">Instagram</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Honeypot -->
          <div style="display:none;" aria-hidden="true">
            <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
          </div>

          <div style="padding-top:0.5rem;">
            <button
              type="submit"
              id="submit-btn"
              class="btn btn-primary"
              style="width:100%; justify-content:center; font-size:0.9375rem; padding:1rem 2rem; cursor:none;"
            >
              Send It →
            </button>
            <p style="font-family:'Jost',sans-serif; font-size:0.6875rem; color:var(--taupe); text-align:center; margin-top:0.75rem;">
              No spam, ever. I'll respond within 1–2 business days.
            </p>
          </div>
        </form>
      </div>

    </div>
  </div>
</section>

</BaseLayout>

<style>
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr !important; }
    .form-two-col { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const honey = form.querySelector<HTMLInputElement>('[name="_honey"]');
    if (honey?.value) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const formData = new FormData(form);
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(formData)),
      });

      if (res.ok) {
        form.style.display = 'none';
        successMsg.style.display = 'block';
        window.scrollTo({ top: (form as HTMLElement).offsetTop - 100, behavior: 'smooth' });
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send It →';
        alert('Something went wrong. Please email riyauppal777@gmail.com directly.');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send It →';
      alert('Something went wrong. Please email riyauppal777@gmail.com directly.');
    }
  });
</script>
