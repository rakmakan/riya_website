---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTestimonials, getClientLogos, isSanityConfigured } from '../lib/queries';
import { imageUrl } from '../lib/sanity';

// ── Fallback data (used until Sanity is populated) ───────────────────────────
const fallbackClients = [
  { name: 'Parimatch',     logo: '/images/parimatch-logo.svg'   },
  { name: 'Cladiator',     logo: '/images/cladiator-logo.svg'   },
  { name: 'Hubsell',       logo: '/images/hubsell-logo.svg'     },
  { name: 'OpenSense Labs',logo: '/images/opensense-logo.svg'   },
  { name: 'IDEMIA',        logo: '/images/idemia-logo.svg'      },
  { name: 'Griphhy',       logo: '/images/gripphy-logo.svg'     },
  { name: 'Storied Inc',   logo: '/images/storied-logo.jpeg'    },
  { name: 'Pre IPO Hype',  logo: '/images/preipohype-logo.jpeg' },
];

const fallbackTestimonials = [
  {
    quote: 'She brought a rare combination of analytical insight and bold creativity. Her ability to craft compelling brand narratives while driving measurable digital growth made a significant impact.',
    name: 'Paras Gang',
    role: 'Founder',
    company: 'Griphhy',
    logo: '/images/gripphy-logo.svg',
  },
  {
    quote: 'Riya is brilliant at creating internal as well as external communications. She has a good understanding of technology and does a great job defining the target audience.',
    name: 'Manisha Dubey',
    role: 'VP Marketing',
    company: 'IDEMIA',
    logo: '/images/idemia-logo.svg',
  },
  {
    quote: 'I highly recommend Riya to anybody needing help in marketing, corporate communications and PR. She is a self-starter with commendable storytelling, analytical and writing skills — all of which make her an excellent marketer.',
    name: 'Karan Sharma',
    role: 'Founder',
    company: 'Hubsell',
    logo: '/images/hubsell-logo.svg',
  },
];

// ── Live data from Sanity (when configured) ───────────────────────────────────
const [sanityTestimonials, sanityClients] = await Promise.all([
  getTestimonials(),
  getClientLogos(),
]);

const clients = sanityClients.length > 0
  ? sanityClients.map(c => ({
      name: c.companyName,
      logo: imageUrl(c.logo, 44) || '',
    }))
  : fallbackClients;

const testimonials = sanityTestimonials.length > 0
  ? sanityTestimonials.map(t => ({
      quote: t.quote,
      name: t.clientName,
      role: t.role,
      company: t.company,
      logo: imageUrl(t.logo, 56) || '',
    }))
  : fallbackTestimonials;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'Airy Alps',
    description: 'Brand positioning consultancy for solopreneurs and DTC founders',
    founder: { '@type': 'Person', name: 'Riya Uppal', jobTitle: 'Brand Positioning Consultant' },
    address: { '@type': 'PostalAddress', addressLocality: 'Toronto', addressRegion: 'ON', addressCountry: 'CA' },
    url: 'https://airyalps.com',
    areaServed: 'Worldwide',
  },
];
---

<BaseLayout
  title="Brand Positioning Consultant for Solopreneurs & DTC Founders | Airy Alps"
  description="Airy Alps helps solopreneurs and DTC founders build sharp brand positioning — and the AI-powered system that executes it consistently. Based in Toronto. Working globally."
  schema={schema}
>

<!-- ══════════════════════════════════════════════
     HERO
════════════════════════════════════════════════ -->
<section
  aria-label="Hero"
  style="
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(3.5rem, 6vw, 5.5rem);
    padding-top: 2rem;
    position: relative;
    overflow: hidden;
  "
>

  <div class="wrap" style="position:relative;">

    <!-- Label row -->
    <div
      class="hero-label-row"
      style="
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
      "
    >
      <span class="t-label">Brand Positioning Consultant</span>
      <div style="flex:1; height:1px; background:var(--border); max-width:120px;"></div>
      <span class="t-label">Toronto · Global</span>
    </div>

    <!-- H1 — word-by-word reveal -->
    <h1
      style="
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(3.5rem, 9vw, 8rem);
        font-weight: 600;
        line-height: 0.97;
        letter-spacing: -0.03em;
        color: var(--espresso);
        max-width: 14ch;
      "
    >
      <div class="hero-line">
        <div class="hero-word"><span>Your</span></div>
        <div class="hero-word"><span>brand</span></div>
        <div class="hero-word"><span>isn't</span></div>
        <div class="hero-word"><span>unclear.</span></div>
      </div>
      <div class="hero-line" style="display:flex; gap:0.25em; flex-wrap:wrap;">
        <div class="hero-word"><span style="font-style:italic;">Your</span></div>
        <div class="hero-word"><span style="font-style:italic;">positioning</span></div>
        <div class="hero-word"><span style="font-style:italic;">is.</span></div>
      </div>
    </h1>

    <!-- Bottom row: subhead + stats + CTA -->
    <div
      class="hero-sub"
      style="
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
        flex-wrap: wrap;
        margin-top: clamp(2.5rem, 5vw, 4rem);
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      "
    >
      <!-- Subhead -->
      <p style="font-family:'Jost',sans-serif; font-size:clamp(0.9375rem, 1.2vw, 1.0625rem); line-height:1.7; color:color-mix(in srgb, var(--espresso) 65%, transparent); max-width: 40ch; flex:1; min-width:240px;">
        I help solopreneurs and DTC founders build the narrative foundation their brand actually needs — then set up the AI system that executes it consistently.
      </p>

      <!-- Stats -->
      <div style="display:flex; gap:clamp(1.5rem, 3vw, 3rem); align-items:flex-end; flex-shrink:0;">
        {[
          { num: '7+', label: 'years' },
          { num: '3', label: 'continents' },
          { num: '6+', label: 'brands' },
        ].map(({ num, label }) => (
          <div style="display:flex; flex-direction:column; align-items:center; gap:0.2rem;">
            <span style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.75rem, 3vw, 2.5rem); font-weight:600; letter-spacing:-0.03em; color:var(--espresso); line-height:1;">{num}</span>
            <span style="font-family:'Jost',sans-serif; font-size:0.625rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--taupe);">{label}</span>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="hero-cta" style="display:flex; flex-direction:column; gap:0.75rem; align-items:flex-end; white-space:nowrap; flex-shrink:0;">
        <a href="/work-with-me" class="btn btn-primary" style="cursor:none;">Let's Build Your Positioning</a>
        <a
          href="/case-studies"
          style="font-family:'Jost',sans-serif; font-size:0.75rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--taupe); text-decoration:none; transition:color 0.2s ease; cursor:none;"
          onmouseenter="this.style.color='var(--espresso)'"
          onmouseleave="this.style.color='var(--taupe)'"
        >
          See the work →
        </a>
      </div>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════════
     CREDENTIAL MARQUEE — Logo strip
════════════════════════════════════════════════ -->
<div style="border-top:1px solid var(--border); border-bottom:1px solid var(--border); background:var(--sand); overflow:hidden; padding-block:1.25rem;" aria-label="Trusted by">
  <p style="font-family:'Jost',sans-serif; font-size:0.6875rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:var(--taupe); text-align:center; margin-bottom:1rem; padding-inline:1rem;">Trusted by founders and teams at</p>
  <div class="marquee-inner" aria-hidden="true">
    {[...clients, ...clients, ...clients, ...clients].map((c) => (
      <div style="padding-inline:2.5rem; display:flex; align-items:center; flex-shrink:0;">
        <img
          src={c.logo}
          alt={c.name}
          style="height:22px; width:auto; max-width:100px; object-fit:contain; filter:grayscale(1) opacity(0.5); mix-blend-mode:multiply;"
        />
      </div>
    ))}
  </div>
</div>


<!-- ══════════════════════════════════════════════
     PROBLEM — Editorial layout
════════════════════════════════════════════════ -->
<section class="section-pad" aria-labelledby="problem-h" style="border-bottom: 1px solid var(--border);">
  <div class="wrap">

    <div style="display:grid; grid-template-columns:1fr; gap:clamp(3rem, 6vw, 5rem);">

      <!-- Label + headline -->
      <div style="display:grid; grid-template-columns:auto 1fr; gap:clamp(2rem, 5vw, 5rem); align-items:start;" data-reveal>
        <span class="t-label" style="padding-top:0.5rem; white-space:nowrap;">The real problem</span>
        <h2
          id="problem-h"
          class="t-h2"
          style="font-size: clamp(2rem, 4.5vw, 3.75rem); font-weight:500;"
        >
          The real reason your<br />content isn't landing
        </h2>
      </div>

      <!-- Body + callout -->
      <div style="display:grid; grid-template-columns:3fr 2fr; gap:clamp(2rem, 6vw, 6rem); align-items:start;" data-reveal class="two-col">

        <div style="display:flex; flex-direction:column; gap:1.25rem;">
          <p class="t-body">You're posting. You're showing up. You've maybe even hired a copywriter. But something still feels off.</p>
          <p class="t-body">Your message sounds like everyone else in your space. You fumble when someone asks what you do. Your content gets likes but not leads.</p>
          <p class="t-body">And no amount of better captions, prettier graphics, or more consistent posting fixes a foundation that was never built right.</p>
        </div>

        <!-- Callout box -->
        <div
          style="
            border-left: 2px solid var(--sienna);
            padding: 2rem 2rem 2rem 2.5rem;
            background: color-mix(in srgb, var(--sienna) 5%, transparent);
          "
        >
          <p
            class="t-quote"
            style="font-size:clamp(1.125rem, 1.8vw, 1.5rem);"
          >
            "That's not a content problem.<br />That's a positioning problem."
          </p>
        </div>

      </div>

      <!-- Pull quote -->
      <div
        data-reveal
        style="border-left: 3px solid var(--sienna); padding: 1.5rem 2rem 1.5rem 2.5rem;"
      >
        <p class="t-quote">
          "No amount of better captions fixes a foundation that was never built right."
        </p>
      </div>

    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════════
     PROCESS
════════════════════════════════════════════════ -->
<section class="section-pad" aria-labelledby="process-h" style="background:var(--sand);">
  <div class="wrap">

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:end; margin-bottom:4rem;" data-reveal class="two-col">
      <h2
        id="process-h"
        class="t-h2"
        style="font-size: clamp(2rem, 4.5vw, 3.75rem); font-weight:500;"
      >
        From fuzzy to<br /><em>unmistakable</em>
      </h2>
      <p class="t-body" style="padding-bottom:0.5rem;">
        Three fixed-scope engagements. No retainers that stretch forever. No vague deliverables.
      </p>
    </div>

    <!-- Stat bar -->
    <div
      data-reveal
      style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        margin-bottom: 3rem;
        border: 1px solid var(--border);
      "
      class="stat-bar"
    >
      {[
        { label: 'Fixed scope', value: 'Always' },
        { label: 'No retainers', value: 'Ever' },
        { label: 'Outcomes-focused', value: 'Guaranteed' },
      ].map(({ label, value }) => (
        <div style="background:var(--parchment); padding:1.25rem 1.5rem;">
          <p class="t-label" style="margin-bottom:0.4rem;">{label}</p>
          <p style="font-family:'Cormorant Garamond',serif; font-size:1.125rem; font-weight:500; color:var(--espresso); letter-spacing:-0.01em;">{value}</p>
        </div>
      ))}
    </div>

    <!-- Process rows -->
    <div data-stagger>
      {[
        {
          n: '01',
          title: 'Positioning Audit',
          detail: "A 90-minute deep dive. Precise diagnosis of where your brand breaks down and what to fix first. You leave with a clear picture of what's working, what isn't, and exactly where to start.",
          price: '$500',
          tag: 'Start here',
        },
        {
          n: '02',
          title: 'Narrative Foundation Sprint',
          detail: '3–4 weeks. Complete positioning foundation: category, audience, differentiation, brand voice, messaging bible. The document that makes every piece of content faster and cleaner to produce.',
          price: 'From $2,500',
          tag: 'Full build',
        },
        {
          n: '03',
          title: 'AI Platform Onboarding',
          detail: "I configure your AI content platform — channels connected, brand voice loaded, first calendar built. So the strategy doesn't sit in a drawer. It ships, consistently, on autopilot.",
          price: 'Included for Sprint clients',
          tag: 'Execution',
        },
      ].map(({ n, title, detail, price, tag }) => (
        <div class="process-row">
          <span class="t-label" style="padding-top:0.2rem; color:var(--taupe);">{n}</span>

          <div>
            <div style="display:flex; align-items:baseline; gap:1.5rem; flex-wrap:wrap;">
              <h3 class="t-h3" style="font-size:clamp(1.25rem, 2.2vw, 1.75rem);">{title}</h3>
              <span style="font-family:'Jost',sans-serif; font-size:0.6875rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--sienna); font-weight:500;">{tag}</span>
            </div>
            <p class="t-body" style="margin-top:0.75rem; max-width:52ch;">{detail}</p>
          </div>

          <div style="text-align:right; padding-top:0.2rem;">
            <span style="font-family:'Cormorant Garamond',serif; font-size:clamp(1rem, 1.5vw, 1.25rem); font-weight:500; color:var(--espresso); white-space:nowrap;">{price}</span>
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top:3rem; padding-top:3rem; border-top:1px solid var(--border); display:flex; justify-content:center;">
      <a href="/work-with-me" class="btn btn-secondary" style="cursor:none;">
        See Full Scope & Pricing
        <span aria-hidden="true">→</span>
      </a>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════════
     PULL QUOTE — Dark section
════════════════════════════════════════════════ -->
<section
  aria-label="Riya's philosophy"
  style="
    background: var(--mahogany);
    padding-block: clamp(5rem, 10vw, 9rem);
    overflow: hidden;
    position: relative;
  "
>
  <!-- Ghost text -->
  <div
    aria-hidden="true"
    style="
      position:absolute;
      bottom:-0.1em;
      right:-0.05em;
      font-family:'Cormorant Garamond',serif;
      font-size:clamp(10rem, 22vw, 20rem);
      font-weight:600;
      line-height:1;
      letter-spacing:-0.04em;
      color:rgba(255,255,255,0.03);
      pointer-events:none;
      user-select:none;
    "
  >02</div>

  <div class="wrap" style="position:relative;">
    <blockquote data-reveal>
      <p
        class="t-quote"
        style="
          font-size: clamp(1.5rem, 3.5vw, 3rem);
          color: var(--parchment);
          max-width: 22ch;
        "
      >
        "Most brand consultants give you a strategy deck and disappear. I give you the foundation and the system that brings it to life."
      </p>
      <cite
        style="
          display:block;
          margin-top:2rem;
          font-family:'Jost',sans-serif;
          font-style:normal;
          font-size:0.75rem;
          letter-spacing:0.1em;
          text-transform:uppercase;
          color:color-mix(in srgb, var(--parchment) 40%, transparent);
        "
      >— Riya Uppal, Founder, Airy Alps</cite>
    </blockquote>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     CASE STUDIES
════════════════════════════════════════════════ -->
<section class="section-pad" aria-labelledby="work-h" style="border-bottom:1px solid var(--border);">
  <div class="wrap">

    <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:4rem; gap:2rem;" data-reveal>
      <h2
        id="work-h"
        class="t-h2"
        style="font-size: clamp(2rem, 4.5vw, 3.75rem); font-weight:500;"
      >The work</h2>
      <a href="/case-studies" class="btn btn-secondary" style="flex-shrink:0; cursor:none;">All case studies</a>
    </div>

    {[
      {
        n: '01',
        cat: 'Brand Architecture',
        title: 'From Stalled to Shipped',
        summary: "A technology company's website stuck for 12 months. Competing opinions, no messaging architecture. Positioning-first rewrite shipped it in weeks.",
        metric: '18% ↑ time on page',
        metric2: 'SEMrush authority 80+',
        slug: 'stalled-to-shipped',
      },
      {
        n: '02',
        cat: 'Messaging Strategy',
        title: 'No More Spray and Pray',
        summary: 'B2B outreach catching very little. CRM data mapped to real buyer psychology. Precision targeting replaced volume spray.',
        metric: '2 major account wins',
        metric2: 'Framework adopted as standard',
        slug: 'crm-precision-messaging',
      },
      {
        n: '03',
        cat: 'Cold Outreach Repositioning',
        title: 'Strategy Before Send',
        summary: 'Cold email generating opens, zero replies. Rebuilt buyer personas, repositioned around tension not features.',
        metric: 'Reply rates increased',
        metric2: 'Pipeline quality improved',
        slug: 'cold-email-repositioning',
      },
    ].map(({ n, cat, title, summary, metric, metric2, slug }) => (
      <a
        href={`/case-studies/${slug}`}
        class="cs-row"
        data-reveal
      >
        <span class="cs-meta t-label" style="padding-top:0.35rem; color:var(--taupe);">[{n}]</span>

        <div>
          <div style="display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap; margin-bottom:0.75rem;">
            <h3 class="cs-title t-h3" style="font-size:clamp(1.25rem, 2vw, 1.5rem);">{title}</h3>
            <span class="cs-meta t-label" style="color:var(--taupe);">{cat}</span>
          </div>
          <p
            class="cs-meta t-body"
            style="font-size:0.875rem; max-width:48ch;"
          >{summary}</p>
        </div>

        <div style="display:flex; flex-direction:column; gap:0.5rem; align-items:flex-start; padding-top:0.25rem;">
          <span
            class="cs-metric"
            style="font-family:'Cormorant Garamond',serif; font-size:1rem; font-weight:500; color:var(--espresso); letter-spacing:-0.01em;"
          >{metric}</span>
          <span
            class="cs-meta"
            style="font-family:'Jost',sans-serif; font-size:0.75rem; color:var(--taupe); letter-spacing:0.04em;"
          >{metric2}</span>
          <span class="cs-arrow t-label" style="margin-top:0.75rem; color:var(--taupe);">Read →</span>
        </div>
      </a>
    ))}

  </div>
</section>


<!-- ══════════════════════════════════════════════
     ABOUT TEASER
════════════════════════════════════════════════ -->
<section class="section-pad" aria-labelledby="about-h" style="background:var(--parchment); overflow:hidden;">
  <div class="wrap">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:clamp(3rem,8vw,7rem); align-items:start; position:relative;" class="two-col">

      <!-- Left -->
      <div data-reveal style="position:relative;">
        <div
          aria-hidden="true"
          style="
            position:absolute;
            top:-0.2em;
            left:-0.15em;
            font-family:'Cormorant Garamond',serif;
            font-size:clamp(8rem, 16vw, 12rem);
            font-weight:600;
            line-height:1;
            letter-spacing:-0.04em;
            color:rgba(28, 21, 18, 0.04);
            pointer-events:none;
            user-select:none;
            z-index:0;
          "
        >7+</div>

        <div style="position:relative; z-index:1; padding-top:clamp(4rem, 8vw, 6rem);">
          <span class="t-label" style="display:block; margin-bottom:1.5rem;">About Riya</span>
          <h2
            id="about-h"
            class="t-h2"
            style="margin-bottom:1.75rem;"
          >
            Enterprise thinking.<br />
            <em>Founder-sized</em><br />
            engagements.
          </h2>
          <p class="t-body" style="margin-bottom:1rem;">
            7+ years building narrative systems for enterprise brands across three continents. At IDEMIA, hubsell, and OpenSense Labs, I led positioning work that moved markets.
          </p>
          <p class="t-body" style="margin-bottom:2.5rem;">
            Now I bring that same rigour to founders — without the agency price tag or the six-month timeline.
          </p>
          <a
            href="/about"
            style="
              font-family:'Jost',sans-serif;
              font-size:0.75rem;
              letter-spacing:0.1em;
              text-transform:uppercase;
              color:var(--espresso);
              text-decoration:none;
              border-bottom:1px solid var(--border);
              padding-bottom:0.25rem;
              transition:border-color 0.2s ease, color 0.2s ease;
              cursor:none;
            "
            onmouseenter="this.style.borderColor='var(--sienna)'; this.style.color='var(--sienna)'"
            onmouseleave="this.style.borderColor='var(--border)'; this.style.color='var(--espresso)'"
          >
            More about Riya →
          </a>
        </div>
      </div>

      <!-- Right: timeline -->
      <div data-reveal class="about-right-col" style="transition-delay: 0.15s; padding-top:clamp(4rem, 8vw, 6rem);">
        <span class="t-label" style="display:block; margin-bottom:1.5rem;">Experience</span>
        <div style="display:flex; flex-direction:column; gap:0;">
          {[
            { year: '2019–2023', co: 'Enterprise & B2B', note: 'IDEMIA · hubsell · OpenSense Labs' },
            { year: '2023–2026', co: 'Independent Consultant', note: 'Griphhy · Parimatch · Cladiator · others' },
            { year: '2026–now',  co: 'Storied Inc', note: 'Narrative strategy · technology founders' },
          ].map(({ year, co, note }) => (
            <div
              style="
                display:grid;
                grid-template-columns:5rem 1fr;
                gap:1.5rem;
                padding-block:1.25rem;
                border-top:1px solid var(--border);
              "
            >
              <span class="t-label" style="color:var(--taupe); padding-top:0.25rem; white-space:nowrap; font-size:0.625rem;">{year}</span>
              <div>
                <p style="font-family:'Cormorant Garamond',serif; font-size:1.0625rem; font-weight:500; letter-spacing:-0.01em; color:var(--espresso);">{co}</p>
                <p style="font-family:'Jost',sans-serif; font-size:0.8125rem; color:var(--taupe); margin-top:0.2rem;">{note}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     TESTIMONIALS
════════════════════════════════════════════════ -->
<section class="section-pad" aria-label="Testimonials" style="background:var(--parchment); border-top:1px solid var(--border);">
  <div class="wrap">

    <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:3.5rem;" data-reveal>
      <span class="t-label">What clients say</span>
      <p style="font-family:'Cormorant Garamond',serif; font-size:1rem; font-style:italic; color:var(--taupe);">Real words. No edits.</p>
    </div>

    <div class="testimonials-grid" data-reveal>
      {testimonials.map((t) => (
        <article class="testimonial-card">

          <!-- Brand logo -->
          <div style="margin-bottom:2rem; padding-bottom:1.5rem; border-bottom:1px solid var(--border);">
            <img
              src={t.logo}
              alt={t.company}
              style="height:28px; width:auto; max-width:120px; object-fit:contain; filter:grayscale(1) brightness(0) opacity(0.55);"
            />
          </div>

          <!-- Opening quote mark -->
          <div aria-hidden="true" style="font-family:'Cormorant Garamond',serif; font-size:4rem; line-height:1; color:var(--sienna); opacity:0.25; margin-bottom:-0.75rem; user-select:none;">"</div>

          <!-- Quote -->
          <blockquote style="margin:0;">
            <p style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.125rem,1.75vw,1.375rem); font-style:italic; line-height:1.65; color:var(--espresso); letter-spacing:-0.01em;">{t.quote}</p>
          </blockquote>

          <!-- Attribution -->
          <footer style="display:flex; align-items:center; gap:1rem; margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border);">
            <div style="width:32px; height:32px; border-radius:50%; background:var(--sand); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-family:'Cormorant Garamond',serif; font-size:0.9375rem; font-weight:500; color:var(--taupe); line-height:1;">{t.name.charAt(0)}</span>
            </div>
            <div>
              <p style="font-family:'Jost',sans-serif; font-size:0.875rem; font-weight:500; color:var(--espresso); line-height:1.2;">{t.name}</p>
              <p style="font-family:'Jost',sans-serif; font-size:0.75rem; color:var(--taupe); margin-top:0.125rem;">{t.role}, {t.company}</p>
            </div>
          </footer>

        </article>
      ))}
    </div>

  </div>
</section>


