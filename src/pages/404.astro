---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Airy Alps"
  description="The page you're looking for doesn't exist. Head back to Airy Alps."
>
  <section class="py-32 md:py-48 text-center">
    <div class="container-site max-w-xl mx-auto">
      <p class="font-fraunces text-8xl font-medium text-brand-ink/10">404</p>
      <h1 class="font-fraunces text-3xl md:text-4xl font-medium text-brand-ink mt-4">
        This page doesn't exist.
      </h1>
      <p class="mt-4 text-brand-ink/60">
        But your positioning problem does — let's fix that instead.
      </p>
      <div class="flex flex-wrap gap-4 justify-center mt-10">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/contact" class="btn-secondary">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>
